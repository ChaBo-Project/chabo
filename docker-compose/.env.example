# ChaBo Docker Compose Environment Configuration
# Copy this file to .env and fill in the values.

# Required API tokens
HF_TOKEN=
QDRANT_API_KEY=

# Set to "local" to start local TEI containers for embedding and reranking.
# Leave empty (or remove) to use remote HuggingFace endpoints from params.cfg.
COMPOSE_PROFILES=

# When COMPOSE_PROFILES=local, set these to point chabo at the local TEI containers:
EMBEDDING_ENDPOINT_URL=http://tei-embedding:80
RERANKER_ENDPOINT_URL=http://tei-reranker:80

# Customize TEI models (must match the vector store embedding model):
TEI_EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
TEI_RERANKER_MODEL=BAAI/bge-reranker-base

# Uncomment if using alternative LLM providers:
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# COHERE_API_KEY=

# ChatUI origin (for non-HTTPS deployments):
# UI_ORIGIN=http://localhost:3000
